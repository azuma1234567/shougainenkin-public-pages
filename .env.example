# 公開後に設定する値(どちらも未設定でも動作します)

# サイトの本番URL(robots.txt / sitemap.xml / OGPで使用)
# 例: NEXT_PUBLIC_SITE_URL=https://shougainenkin-support.vercel.app
NEXT_PUBLIC_SITE_URL=

# App StoreのURL。設定するとトップページに「App Storeでダウンロード」ボタンが表示されます。
# 未設定の間は「App Storeで近日公開」と表示されます。
# 例: NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/jp/app/idXXXXXXXXXX
NEXT_PUBLIC_APP_STORE_URL=
